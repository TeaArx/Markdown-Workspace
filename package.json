{
  "name": "markdown-workspace",
  "productName": "Markdown Workspace",
  "version": "1.0.2",
  "description": "A desktop Markdown editor built with Electron, Vue, secure IPC, JSON settings and local notes.",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "start": "electron-vite dev",
    "build:app": "electron-vite build",
    "build": "npm run dist",
    "pack": "npm run build:app && electron-builder --dir --publish never",
    "package": "npm run pack",
    "make": "npm run dist",
    "dist": "npm run dist:win",
    "dist:win": "npm run build:app && electron-builder --win nsis --x64 --publish never",
    "release": "npm run build:app && electron-builder --win nsis --x64 --publish always",
    "publish": "npm run release",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
  "author": {
    "name": "TeaArx",
    "email": "egorka.truhin@yandex.ru"
  },
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.34",
    "electron": "42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "build": {
    "appId": "com.markdown-workspace.app",
    "productName": "Markdown Workspace",
    "artifactName": "Markdown-Workspace-${version}-${arch}.${ext}",
    "asar": true,
    "electronUpdaterCompatibility": ">=2.16",
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerSidebar": "installerSidebar.bmp",
      "uninstallerSidebar": "installerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Markdown Workspace",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "language": "1049"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TeaArx",
        "repo": "Markdown-Workspace",
        "channel": "latest",
        "publishAutoUpdate": true,
        "releaseType": "release"
      }
    ]
  }
}
